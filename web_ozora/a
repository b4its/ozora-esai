/* ─────────────────────────────────────────────
   REALTIME POLLING ENGINE
───────────────────────────────────────────── */
const RT = (function(){
    const INTERVAL = 5000;
    const URL_PATH = window.location.pathname;
    let timer=null, latestId=0, syncedAt=null;

    function maxIdFromDOM(){
        let mx=0;
        document.querySelectorAll('#tbl-body tr[data-id]').forEach(r=>{
            const id=parseInt(r.dataset.id||0);
            if(id>mx) mx=id;
        });
        return mx;
    }

    async function fetch_data(){
        try{
            const u=new URL(URL_PATH, window.location.origin);
            u.searchParams.set('since_id', latestId);
            const res=await fetch(u.toString(),{
                headers:{'X-Requested-With':'XMLHttpRequest','Accept':'application/json'},
                credentials:'same-origin'
            });
            if(!res.ok) throw new Error('HTTP '+res.status);
            return await res.json();
        }catch(e){
            console.warn('[RT]',e);
            return null;
        }
    }

    function insertRows(records){
        if(!records||!records.length) return;
        const tbody = document.getElementById('tbl-body');
        const emptyR = document.getElementById('empty-row');
        if(emptyR) emptyR.remove();
        let added=0;
        records.forEach(s=>{
            if(parseInt(s.id)<=latestId) return;
            if(tbody.querySelector(`tr[data-id="${s.id}"]`)) return;
            const tmp=document.createElement('tbody');
            tmp.innerHTML=buildRow(s);
            const row=tmp.firstElementChild;
            const first=tbody.querySelector('tr.db-row');
            first ? tbody.insertBefore(row,first) : tbody.appendChild(row);
            requestAnimationFrame(()=>{
                row.classList.add('row-flash');
                setTimeout(()=>row.classList.remove('row-flash'),1400);
            });
            added++;
        });
        if(records.length){
            const mx=Math.max(...records.map(s=>parseInt(s.id)));
            if(mx>latestId) latestId=mx;
        }
        if(added>0){ pg.p=1; pg.render(); }
    }

    async function poll(){
        setIndicator('syncing');
        const data=await fetch_data();
        if(data&&data.sensor_data){
            insertRows(data.sensor_data);
            syncedAt=new Date();
            updateSyncTxt();
            setIndicator('live');
        } else {
            setIndicator('offline');
        }
    }

    function setIndicator(state){
        const badge=document.getElementById('rt-badge');
        const dot  =document.getElementById('rt-dot');
        const lbl  =document.getElementById('rt-lbl');
        if(!badge) return;
        badge.className='rt-badge '+state;
        dot.className  ='rt-dot'+(state==='live'?'':' paused');
        lbl.textContent= state==='live'?'LIVE': state==='syncing'?'SYNCING':'OFFLINE';
    }

    function updateSyncTxt(){
        const el=document.getElementById('sync-txt');
        if(!el) return;
        if(!syncedAt){el.textContent='Never';return;}
        const d=Math.floor((Date.now()-syncedAt)/1000);
        if(d<5)        el.textContent='Just now';
        else if(d<60)  el.textContent=`${d}s ago`;
        else if(d<3600)el.textContent=`${Math.floor(d/60)}m ago`;
        else           el.textContent=syncedAt.toLocaleTimeString();
    }
    setInterval(updateSyncTxt,1000);

    return {
        init(){
            latestId=maxIdFromDOM();
            setIndicator('syncing');
            poll();
            timer=setInterval(poll,INTERVAL);
        },
        stop(){ clearInterval(timer); setIndicator('offline'); }
    };
})();

/* ─────────────────────────────────────────────
   PAGINATION
───────────────────────────────────────────── */
const pg = {
    p:1, pp:10, tot:1,
    rows(){ return [...document.querySelectorAll('#tbl-body tr:not(#empty-row)')]; },
    init(){ this.p=1; this.render(); },
    setPerPage(n){ this.pp=n; this.p=1; this.render(); },
    go(n){
        this.tot=Math.max(1,Math.ceil(this.rows().length/this.pp));
        if(n<1||n>this.tot) return;
        this.p=n; this.render();
    },
    render(){
        const all=this.rows(), total=all.length;
        this.tot=Math.max(1,Math.ceil(total/this.pp));
        if(this.p>this.tot) this.p=this.tot;
        if(this.p<1) this.p=1;
        const s=(this.p-1)*this.pp, e=s+this.pp;
        all.forEach((r,i)=>{
            r.style.display=(i>=s&&i<e)?'':'none';
        });
        const info=document.getElementById('pg-info');
        info.textContent = total===0?'No records':`Showing ${s+1}–${Math.min(e,total)} of ${total} records`;
        const meta=document.getElementById('tbl-meta');
        if(meta) meta.textContent=`${total} record${total!==1?'s':''}`;
        ['pg-first','pg-prev'].forEach(id=>document.getElementById(id).disabled=this.p<=1);
        ['pg-next','pg-last'].forEach(id=>document.getElementById(id).disabled=this.p>=this.tot);
        this.renderNums();
        const bar=document.getElementById('pg-bar');
        bar.style.display=(total<=this.pp&&this.tot<=1)?'none':'flex';
    },
    renderNums(){
        const c=document.getElementById('pg-nums');
        c.innerHTML='';
        const cur=this.p, tot=this.tot;
        const pages=new Set([1,tot]);
        for(let i=cur-1;i<=cur+1;i++) if(i>=1&&i<=tot) pages.add(i);
        const sorted=[...pages].sort((a,b)=>a-b);
        let prev=0;
        sorted.forEach(n=>{
            if(n-prev>1){ const s=document.createElement('span'); s.className='pellipsis'; s.textContent='…'; c.appendChild(s); }
            const b=document.createElement('button');
            b.className='pnum'+(n===cur?' on':'');
            b.textContent=n;
            b.onclick=()=>pg.go(n);
            c.appendChild(b);
            prev=n;
        });
    }
};

