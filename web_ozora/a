{% load static %}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ozora Panel — Textile Wastewater Treatment</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&family=Clash+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Fallback for Clash Display -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="{% static 'css/iziToast.min.css' %}">

    <style>
    /* ──────────────────────────────────────────────
       DESIGN TOKENS
    ────────────────────────────────────────────── */
    :root {
        --font-display: 'Outfit', 'Space Grotesk', sans-serif;
        --font-body:    'Space Grotesk', sans-serif;
        --font-mono:    'JetBrains Mono', monospace;

        /* Sidebar */
        --sb-w: 256px;
        --sb-collapsed: 68px;
        --top-h: 60px;

        /* Animation */
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
        --dur: 0.3s;
    }

    /* ── DARK (default) ── */
    [data-theme="dark"] {
        --bg:         #080C14;
        --bg-1:       #0D1220;
        --bg-2:       #111827;
        --bg-3:       #161D2E;
        --bg-4:       #1C2539;
        --border:     rgba(255,255,255,0.07);
        --border-2:   rgba(255,255,255,0.12);
        --tx:         #F0F4FF;
        --tx-2:       #8896B3;
        --tx-3:       #4D5F80;
        --glow-a:     rgba(56,189,248,0.18);
        --glow-b:     rgba(168,85,247,0.15);

        /* Accent palette */
        --cyan:       #38BDF8;
        --cyan-d:     #0EA5E9;
        --violet:     #A855F7;
        --emerald:    #10B981;
        --rose:       #F43F5E;
        --amber:      #F59E0B;
        --indigo:     #6366F1;

        /* Glassmorphism */
        --glass:      rgba(255,255,255,0.04);
        --glass-2:    rgba(255,255,255,0.07);
    }

    /* ── LIGHT ── */
    [data-theme="light"] {
        --bg:         #F0F4FF;
        --bg-1:       #FFFFFF;
        --bg-2:       #FAFBFF;
        --bg-3:       #F5F7FF;
        --bg-4:       #EEF2FF;
        --border:     rgba(0,0,0,0.07);
        --border-2:   rgba(0,0,0,0.12);
        --tx:         #0D1117;
        --tx-2:       #5A6A8A;
        --tx-3:       #9BA5BC;
        --glow-a:     rgba(56,189,248,0.12);
        --glow-b:     rgba(168,85,247,0.1);
        --cyan:       #0284C7;
        --cyan-d:     #0369A1;
        --violet:     #7C3AED;
        --emerald:    #059669;
        --rose:       #E11D48;
        --amber:      #D97706;
        --indigo:     #4F46E5;
        --glass:      rgba(0,0,0,0.02);
        --glass-2:    rgba(0,0,0,0.04);
    }

    /* ──────────────────────────────────────────────
       RESET & BASE
    ────────────────────────────────────────────── */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--tx);
        min-height: 100vh;
        display: flex;
        overflow-x: hidden;
        transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
    }

    /* Noise texture overlay */
    body::before {
        content: '';
        position: fixed; inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
        pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 4px; }

    /* ──────────────────────────────────────────────
       SIDEBAR
    ────────────────────────────────────────────── */
    .sidebar {
        position: fixed;
        inset: 0 auto 0 0;
        width: var(--sb-w);
        background: var(--bg-1);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        z-index: 300;
        transition: width var(--dur) var(--ease), transform var(--dur) var(--ease);
        overflow: hidden;
    }
    .sidebar::after {
        content:'';
        position: absolute;
        top: 0; right: 0;
        width: 1px;
        height: 100%;
        background: linear-gradient(180deg, transparent, var(--cyan-d), var(--violet), transparent);
        opacity: 0.3;
    }
    .sidebar.collapsed { width: var(--sb-collapsed); }
    @media (max-width: 767px) {
        .sidebar { transform: translateX(-100%); width: var(--sb-w) !important; }
        .sidebar.open { transform: translateX(0); box-shadow: 20px 0 60px rgba(0,0,0,0.5); }
    }

    /* Logo */
    .sb-logo {
        display: flex; align-items: center; gap: 12px;
        padding: 0 16px;
        height: var(--top-h);
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        overflow: hidden;
        flex-shrink: 0;
    }
    .sb-logo-mark {
        width: 36px; height: 36px; flex-shrink: 0;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--cyan), var(--violet));
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; color: #fff;
        box-shadow: 0 0 20px var(--glow-a), 0 0 40px var(--glow-b);
        position: relative;
    }
    .sb-logo-mark::after {
        content: '';
        position: absolute; inset: -1px;
        border-radius: 11px;
        background: linear-gradient(135deg, var(--cyan), var(--violet));
        z-index: -1;
        opacity: 0.4;
        filter: blur(6px);
    }
    .sb-logo-text {
        font-family: var(--font-display);
        font-weight: 700; font-size: 1rem;
        color: var(--tx);
        white-space: nowrap;
        transition: opacity var(--dur), width var(--dur);
    }
    .sb-logo-text small {
        display: block;
        font-size: 0.65rem;
        color: var(--tx-2);
        font-weight: 400;
        letter-spacing: 0.5px;
    }
    .sidebar.collapsed .sb-logo-text { opacity: 0; width: 0; overflow: hidden; }

    /* Toggle */
    .sb-toggle {
        position: absolute;
        top: 14px; right: 12px;
        width: 28px; height: 28px;
        background: var(--bg-3);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--tx-2);
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px;
        transition: all 0.2s;
    }
    .sb-toggle:hover { background: var(--bg-4); color: var(--cyan); border-color: var(--cyan); }
    @media (max-width: 767px) { .sb-toggle { display: none; } }

    /* Nav */
    .sb-nav {
        flex: 1;
        padding: 16px 10px;
        overflow-y: auto;
        overflow-x: hidden;
    }
    .sb-section-label {
        font-size: 0.6rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--tx-3);
        padding: 8px 8px 4px;
        white-space: nowrap;
        transition: opacity var(--dur);
    }
    .sidebar.collapsed .sb-section-label { opacity: 0; }

    .nav-link {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 10px;
        border-radius: 10px;
        cursor: pointer;
        color: var(--tx-2);
        font-size: 0.83rem;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        position: relative;
        transition: all 0.2s;
        border: 1px solid transparent;
        margin-bottom: 2px;
    }
    .nav-link:hover:not(.disabled) {
        background: var(--glass-2);
        color: var(--tx);
    }
    .nav-link.active {
        background: linear-gradient(135deg, rgba(56,189,248,0.1), rgba(168,85,247,0.1));
        color: var(--cyan);
        border-color: rgba(56,189,248,0.2);
        font-weight: 600;
    }
    .nav-link.disabled { opacity: 0.35; cursor: not-allowed; pointer-events: none; }
    .nav-icon {
        width: 30px; height: 30px; flex-shrink: 0;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px;
        background: var(--glass);
        transition: all 0.2s;
    }
    .nav-link.active .nav-icon {
        background: linear-gradient(135deg, var(--cyan), var(--violet));
        color: #fff;
        box-shadow: 0 4px 12px var(--glow-a);
    }
    .nav-text { transition: opacity var(--dur); }
    .sidebar.collapsed .nav-text { opacity: 0; width: 0; overflow: hidden; }

    /* Tooltip on collapsed */
    .sidebar.collapsed .nav-link[data-tip]:hover::after {
        content: attr(data-tip);
        position: absolute;
        left: calc(var(--sb-collapsed) + 4px);
        top: 50%; transform: translateY(-50%);
        background: var(--bg-2);
        border: 1px solid var(--border-2);
        color: var(--tx);
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 0.75rem;
        white-space: nowrap;
        pointer-events: none;
        z-index: 400;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    /* Footer */
    .sb-footer { padding: 10px; border-top: 1px solid var(--border); flex-shrink: 0; }
    .logout-link {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 10px;
        border-radius: 10px;
        color: var(--rose);
        font-size: 0.83rem; font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid transparent;
        white-space: nowrap; overflow: hidden;
    }
    .logout-link:hover { background: rgba(244,63,94,0.1); border-color: rgba(244,63,94,0.2); color: var(--rose); }
    .logout-icon { width: 30px; height: 30px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 13px; }
    .sidebar.collapsed .logout-text { opacity: 0; width: 0; overflow: hidden; }

    /* ──────────────────────────────────────────────
       BACKDROP (mobile)
    ────────────────────────────────────────────── */
    .backdrop {
        display: none;
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(8px);
        z-index: 299;
    }
    .backdrop.visible { display: block; animation: fadeIn 0.2s; }

    /* ──────────────────────────────────────────────
       LAYOUT
    ────────────────────────────────────────────── */
    .shell {
        flex: 1;
        margin-left: var(--sb-w);
        display: flex; flex-direction: column;
        min-height: 100vh;
        transition: margin-left var(--dur) var(--ease);
    }
    .shell.sb-collapsed { margin-left: var(--sb-collapsed); }
    @media (max-width: 767px) { .shell { margin-left: 0 !important; } }

    /* ──────────────────────────────────────────────
       TOPBAR
    ────────────────────────────────────────────── */
    .topbar {
        height: var(--top-h);
        background: var(--bg-1);
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 24px;
        position: sticky; top: 0; z-index: 200;
        gap: 16px;
    }
    @media (max-width: 640px) { .topbar { padding: 0 14px; } }
    .topbar-left { display: flex; align-items: center; gap: 14px; min-width: 0; }
    .mobile-menu {
        display: none; width: 36px; height: 36px;
        background: var(--bg-3); border: 1px solid var(--border);
        border-radius: 8px; cursor: pointer;
        align-items: center; justify-content: center;
        color: var(--tx-2); font-size: 14px; flex-shrink: 0;
        transition: all 0.2s;
    }
    .mobile-menu:hover { color: var(--cyan); border-color: var(--cyan); }
    @media (max-width: 767px) { .mobile-menu { display: flex; } }

    .page-info h1 {
        font-family: var(--font-display);
        font-size: 1rem; font-weight: 700;
        color: var(--tx);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .page-info p { font-size: 0.7rem; color: var(--tx-2); margin-top: 1px; }
    .topbar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

    /* Theme switcher */
    .theme-row {
        display: flex; align-items: center;
        background: var(--bg-3); border: 1px solid var(--border);
        border-radius: 50px; padding: 3px; gap: 2px;
    }
    .tbtn {
        width: 28px; height: 28px; border: none; background: transparent;
        border-radius: 50%; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: var(--tx-3); font-size: 11px; transition: all 0.2s;
    }
    .tbtn:hover { color: var(--tx); }
    .tbtn.on { background: var(--bg-1); color: var(--cyan); box-shadow: 0 2px 8px rgba(0,0,0,0.2); }

    /* Token */
    .token-chip {
        background: var(--bg-3);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 4px 10px;
        font-family: var(--font-mono);
        font-size: 0.66rem;
        color: var(--tx-2);
        display: none;
    }
    @media (min-width: 640px) { .token-chip { display: block; } }

    /* Status badge */
    .status-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 4px 10px; border-radius: 50px;
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.5px;
        white-space: nowrap;
    }
    .status-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
    .badge-ok  { background: rgba(16,185,129,0.12); color: var(--emerald); }
    .badge-err { background: rgba(244,63,94,0.12);  color: var(--rose); }

    /* ──────────────────────────────────────────────
       MAIN CONTENT
    ────────────────────────────────────────────── */
    main { flex: 1; padding: 24px; position: relative; z-index: 1; }
    @media (max-width: 1024px) { main { padding: 18px; } }
    @media (max-width: 640px)  { main { padding: 12px; } }

    .view { display: none; }
    .view.on {
        display: block;
        animation: slideUp 0.4s var(--ease);
    }
    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* ──────────────────────────────────────────────
       CONNECTION VIEW
    ────────────────────────────────────────────── */
    .connect-stage {
        min-height: calc(100vh - var(--top-h) - 48px);
        display: flex; align-items: center; justify-content: center; flex-direction: column;
        gap: 32px; text-align: center;
    }
    .ring-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
    .ring {
        position: absolute; border-radius: 50%;
        border: 1.5px solid var(--cyan);
        opacity: 0; pointer-events: none;
    }
    .ring-1 { width: 240px; height: 240px; }
    .ring-2 { width: 280px; height: 280px; animation-delay: 0.5s; }
    .ring.pulse { animation: ringPulse 2.5s infinite var(--ease); }
    .ring-2.pulse { animation: ringPulse 2.5s 0.5s infinite var(--ease); }
    @keyframes ringPulse {
        0%   { transform: scale(0.85); opacity: 0.5; }
        100% { transform: scale(1.2);  opacity: 0; }
    }

    .hw-btn {
        width: 176px; height: 176px;
        border-radius: 50%; border: none;
        cursor: pointer; color: #fff;
        font-family: var(--font-display);
        font-size: 0.85rem; font-weight: 700; letter-spacing: 1px;
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
        transition: transform 0.3s var(--ease), box-shadow 0.3s;
        position: relative; z-index: 2;
    }
    .hw-btn i { font-size: 2.8rem; }
    .hw-btn:hover { transform: scale(1.05); }
    .hw-btn:active { transform: scale(0.95); }
    .hw-unlinked {
        background: linear-gradient(145deg, #F59E0B, #D97706);
        box-shadow: 0 0 40px rgba(245,158,11,0.3), 0 16px 40px rgba(0,0,0,0.4);
    }
    .hw-linked {
        background: linear-gradient(145deg, var(--cyan), var(--indigo));
        box-shadow: 0 0 40px var(--glow-a), 0 16px 40px rgba(0,0,0,0.4);
    }
    .hw-done {
        background: linear-gradient(145deg, var(--emerald), #059669);
        box-shadow: 0 0 40px rgba(16,185,129,0.3), 0 16px 40px rgba(0,0,0,0.4);
    }
    .connect-hint { color: var(--tx-2); font-size: 0.9rem; }

    /* ──────────────────────────────────────────────
       MONITORING HEADER / PROCESS BAR
    ────────────────────────────────────────────── */
    .proc-bar {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; flex-wrap: wrap;
        background: var(--bg-1);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 18px 22px;
        margin-bottom: 20px;
        position: relative; overflow: hidden;
    }
    .proc-bar::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, var(--cyan), var(--violet));
    }
    .proc-bar-info h3 {
        font-family: var(--font-display);
        font-size: 0.95rem; font-weight: 700; margin-bottom: 3px;
    }
    .proc-bar-info p { font-size: 0.75rem; color: var(--tx-2); }

    .proc-btn {
        width: 44px; height: 44px;
        border-radius: 12px; border: none; cursor: pointer;
        color: #fff; font-size: 1rem;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.25s; flex-shrink: 0;
    }
    .proc-standby { background: var(--bg-3); color: var(--tx-2); border: 1px solid var(--border); }
    .proc-active  { background: linear-gradient(135deg, var(--cyan), var(--indigo)); box-shadow: 0 6px 16px var(--glow-a); }
    .proc-done    { background: linear-gradient(135deg, var(--emerald), #059669); box-shadow: 0 6px 16px rgba(16,185,129,0.35); }

    /* ──────────────────────────────────────────────
       METRICS GRID
    ────────────────────────────────────────────── */
    .metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
        margin-bottom: 20px;
    }
    @media (max-width: 640px) { .metrics { grid-template-columns: 1fr; gap: 12px; } }

    .metric-card {
        border-radius: 18px;
        padding: 22px;
        position: relative; overflow: hidden;
        min-height: 168px;
        display: flex; flex-direction: column; justify-content: space-between;
        border: 1px solid rgba(255,255,255,0.06);
        transition: transform 0.25s var(--ease), box-shadow 0.25s;
    }
    .metric-card:hover { transform: translateY(-3px); }

    .mc-temp  { background: linear-gradient(145deg, #B91C1C 0%, #7C3AED 100%); box-shadow: 0 8px 32px rgba(185,28,28,0.25); }
    .mc-ph    { background: linear-gradient(145deg, #BE185D 0%, #7C3AED 100%); box-shadow: 0 8px 32px rgba(190,24,93,0.25); }
    .mc-speed { background: linear-gradient(145deg, #1D4ED8 0%, #6D28D9 100%); box-shadow: 0 8px 32px rgba(29,78,216,0.25); }
    .mc-color { background: var(--bg-1); border: 1px solid var(--border); color: var(--tx); box-shadow: 0 4px 16px rgba(0,0,0,0.1); }
    .mc-timer { background: linear-gradient(145deg, #0E7490 0%, #1D4ED8 100%); box-shadow: 0 8px 32px rgba(14,116,144,0.25); }

    .mc-label {
        font-size: 0.63rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 2px;
        opacity: 0.7; margin-bottom: 6px;
    }
    .mc-color .mc-label { color: var(--tx-2); opacity: 1; }

    .mc-value {
        font-family: var(--font-mono);
        font-size: 3rem; font-weight: 500;
        letter-spacing: -3px; line-height: 1;
        color: #fff;
    }
    .mc-unit { font-size: 0.9rem; letter-spacing: 0; font-weight: 600; opacity: 0.75; }
    .mc-color .mc-value { color: var(--tx); }

    /* Wave */
    .mc-wave { position: absolute; bottom: 0; left: 0; right: 0; height: 70px; opacity: 0.15; pointer-events: none; }

    /* Color card specifics */
    .color-bar { width: 100%; height: 56px; border-radius: 10px; margin: 10px 0; transition: background 0.4s ease; border: 1px solid var(--border); }
    .color-name-txt { font-size: 0.82rem; font-weight: 600; color: var(--tx); }
    .rgb-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-top: auto; }
    .rgb-chip {
        background: var(--bg-3); border: 1px solid var(--border);
        border-radius: 8px; padding: 7px; text-align: center;
    }
    .rgb-num { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 500; display: block; }
    .rgb-ch  { font-size: 0.6rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; display: block; margin-top: 2px; }
    .cr { color: #EF4444; } .cg { color: #10B981; } .cb { color: #38BDF8; }

    /* Timer card */
    .timer-big { font-family: var(--font-mono); font-size: 2.6rem; font-weight: 400; letter-spacing: -2px; line-height: 1; color: #fff; }
    .timer-sub { font-family: var(--font-mono); font-size: 0.75rem; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .proc-pill {
        display: inline-flex; align-items: center;
        padding: 4px 10px; border-radius: 20px;
        font-size: 0.65rem; font-weight: 700; letter-spacing: 1px;
        background: rgba(255,255,255,0.15); backdrop-filter: blur(4px);
        color: #fff; width: fit-content;
    }

    /* ──────────────────────────────────────────────
       CHART CARD
    ────────────────────────────────────────────── */
    .chart-card {
        background: var(--bg-1);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 22px;
        margin-bottom: 20px;
        position: relative; overflow: hidden;
    }
    .card-head {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
    }
    .card-title {
        font-family: var(--font-display);
        font-size: 0.9rem; font-weight: 700;
        display: flex; align-items: center; gap: 8px;
    }
    .card-title i { color: var(--cyan); font-size: 13px; }

    /* ──────────────────────────────────────────────
       REALTIME BADGE
    ────────────────────────────────────────────── */
    .rt-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 4px 10px; border-radius: 20px;
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.5px;
        white-space: nowrap;
        transition: all 0.3s;
    }
    .rt-badge.live    { background: rgba(16,185,129,0.12); color: var(--emerald); border: 1px solid rgba(16,185,129,0.25); }
    .rt-badge.syncing { background: rgba(56,189,248,0.12); color: var(--cyan);    border: 1px solid rgba(56,189,248,0.25); }
    .rt-badge.offline { background: rgba(244,63,94,0.12);  color: var(--rose);    border: 1px solid rgba(244,63,94,0.25); }
    .rt-dot {
        width: 5px; height: 5px; border-radius: 50%;
        background: currentColor;
        animation: rtBlink 1.5s infinite;
    }
    .rt-dot.paused { animation: none; opacity: 0.3; }
    @keyframes rtBlink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

    /* ──────────────────────────────────────────────
       LOG TABLE
    ────────────────────────────────────────────── */
    .log-card {
        background: var(--bg-1);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        margin-bottom: 20px;
    }
    .log-head {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
    }
    .log-head-left  { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .log-head-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

    .sync-txt {
        font-family: var(--font-mono);
        font-size: 0.68rem; color: var(--tx-3);
        display: flex; align-items: center; gap: 5px;
    }

    /* Rows/page select */
    .rpp-sel {
        display: flex; align-items: center; gap: 6px;
    }
    .rpp-sel label { font-size: 0.72rem; color: var(--tx-3); white-space: nowrap; }
    .rpp-sel select {
        font-family: var(--font-mono); font-size: 0.72rem;
        background: var(--bg-3); color: var(--tx);
        border: 1px solid var(--border); border-radius: 7px;
        padding: 3px 8px; cursor: pointer; outline: none;
    }

    .tbl-scroll { overflow-x: auto; }
    table {
        width: 100%; border-collapse: collapse;
        min-width: 680px; font-size: 0.82rem;
    }
    thead th {
        text-align: left;
        padding: 10px 16px;
        font-size: 0.63rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1.5px;
        color: var(--tx-3);
        background: var(--bg-3);
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }
    tbody td {
        padding: 11px 16px;
        border-bottom: 1px solid var(--border);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--tx);
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr { transition: background 0.15s; }
    tbody tr:hover { background: var(--glass-2); }

    /* pH column color coding */
    td.ph-cell { font-weight: 600; }
    td.ph-acidic  { color: #F87171; }
    td.ph-neutral { color: #34D399; }
    td.ph-basic   { color: #60A5FA; }

    /* Inline badges */
    .pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 9px; border-radius: 50px;
        font-size: 0.64rem; font-weight: 700; letter-spacing: 0.3px;
        white-space: nowrap; font-family: var(--font-body);
    }
    .pill-ok   { background: rgba(16,185,129,0.12);  color: #10B981; }
    .pill-proc { background: rgba(56,189,248,0.12);  color: #38BDF8; }
    .pill-bad  { background: rgba(244,63,94,0.12);   color: #F43F5E; }
    .pill-warn { background: rgba(245,158,11,0.12);  color: #F59E0B; }

    /* New row animation */
    @keyframes rowNew {
        0%   { background: rgba(56,189,248,0.15); transform: translateY(-4px); opacity: 0; }
        25%  { opacity: 1; transform: translateY(0); }
        100% { background: transparent; }
    }
    .row-flash { animation: rowNew 1.4s var(--ease) forwards; }

    /* Skeleton */
    .sk-cell {
        height: 12px; border-radius: 4px;
        background: linear-gradient(90deg, var(--bg-3) 25%, var(--border-2) 50%, var(--bg-3) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
    }
    @keyframes shimmer { 0%{background-position:200% 0;} 100%{background-position:-200% 0;} }

    /* ──────────────────────────────────────────────
       PAGINATION
    ────────────────────────────────────────────── */
    .pg-bar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap; gap: 8px;
    }
    .pg-info { font-family: var(--font-mono); font-size: 0.7rem; color: var(--tx-3); }
    .pg-btns { display: flex; align-items: center; gap: 4px; }
    .pbt {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: var(--bg-3);
        color: var(--tx);
        font-size: 0.7rem; cursor: pointer;
        transition: all 0.15s;
    }
    .pbt:hover:not(:disabled) { background: rgba(56,189,248,0.1); border-color: var(--cyan); color: var(--cyan); }
    .pbt:disabled { opacity: 0.25; cursor: not-allowed; }
    .pnum {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 30px; height: 30px; padding: 0 6px;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: var(--bg-3); color: var(--tx);
        font-family: var(--font-mono); font-size: 0.72rem;
        cursor: pointer; transition: all 0.15s;
    }
    .pnum:hover { background: rgba(56,189,248,0.08); border-color: var(--cyan); color: var(--cyan); }
    .pnum.on { background: var(--cyan); border-color: var(--cyan); color: #fff; font-weight: 600; }
    .pellipsis {
        display: inline-flex; align-items: center; justify-content: center;
        width: 24px; height: 30px; font-size: 0.72rem;
        color: var(--tx-3); pointer-events: none;
        font-family: var(--font-mono);
    }

    /* ──────────────────────────────────────────────
       OVERLAYS
    ────────────────────────────────────────────── */
    .modal {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.85); backdrop-filter: blur(16px);
        display: none; align-items: center; justify-content: center;
        z-index: 9999; padding: 20px;
    }
    .modal.on { display: flex; animation: fadeIn 0.25s; }
    .modal-box {
        background: var(--bg-2);
        border: 1px solid var(--border-2);
        border-radius: 24px;
        padding: 40px 36px;
        text-align: center;
        max-width: 360px;
        color: var(--tx);
        position: relative; overflow: hidden;
    }
    .modal-box::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, var(--cyan), var(--violet));
    }
    .modal-ico { font-size: 2.8rem; margin-bottom: 20px; display: block; }
    .modal-box h3 { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; margin-bottom: 8px; }
    .modal-box p  { font-size: 0.85rem; color: var(--tx-2); }

    /* ──────────────────────────────────────────────
       RESPONSIVE HELPERS
    ────────────────────────────────────────────── */
    @media (max-width: 480px) {
        .log-head { padding: 12px 14px; }
        main td, main th { padding: 9px 12px; }
        .mc-value { font-size: 2.4rem; }
        .timer-big { font-size: 2rem; }
    }
    @media (max-width: 360px) {
        .metrics { grid-template-columns: 1fr; }
    }

    /* Table meta */
    .tbl-meta { font-family: var(--font-mono); font-size: 0.7rem; color: var(--tx-3); white-space: nowrap; }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 48px 20px;
        color: var(--tx-3);
    }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; }
    .empty-state p { font-size: 0.85rem; }
    </style>
</head>
<body>

<!-- ═══════ SIDEBAR ═══════ -->
<aside class="sidebar" id="sidebar">
    <a class="sb-logo" href="#">
        <div class="sb-logo-mark"><i class="fa-solid fa-flask-vial"></i></div>
        <div class="sb-logo-text">
            Ozora Panel
            <small>Wastewater Treatment</small>
        </div>
    </a>
    <button class="sb-toggle" id="sb-toggle" onclick="toggleSidebar()">
        <i class="fa-solid fa-angles-left" id="sb-icon"></i>
    </button>

    <nav class="sb-nav">
        <div class="sb-section-label">Navigation</div>
        <a class="nav-link active" id="nl-conn" data-tip="Connection" onclick="switchView('connection'); return false;" href="#">
            <div class="nav-icon"><i class="fa-solid fa-tower-broadcast"></i></div>
            <span class="nav-text">Connection</span>
        </a>
        <a class="nav-link disabled" id="nl-mon" data-tip="Monitoring" onclick="switchView('monitoring'); return false;" href="#">
            <div class="nav-icon"><i class="fa-solid fa-chart-area"></i></div>
            <span class="nav-text">Monitoring</span>
        </a>
    </nav>

    <div class="sb-footer">
        <a href="{% url 'logout' %}" class="logout-link">
            <div class="logout-icon"><i class="fa-solid fa-right-from-bracket"></i></div>
            <span class="logout-text">Logout</span>
        </a>
    </div>
</aside>

<!-- Mobile backdrop -->
<div class="backdrop" id="backdrop" onclick="closeMobile()"></div>

<!-- ═══════ SHELL ═══════ -->
<div class="shell" id="shell">

    <!-- TOPBAR -->
    <header class="topbar">
        <div class="topbar-left">
            <button class="mobile-menu" onclick="openMobile()">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="page-info">
                <h1 id="page-title">Device Connection</h1>
                <p id="page-sub">Textile Wastewater Treatment System</p>
            </div>
        </div>
        <div class="topbar-right">
            <div class="theme-row">
                <button class="tbtn" id="tbtn-light"  onclick="setTheme('light')"  title="Light"><i class="fa-solid fa-sun"></i></button>
                <button class="tbtn" id="tbtn-system" onclick="setTheme('system')" title="System"><i class="fa-solid fa-desktop"></i></button>
                <button class="tbtn on" id="tbtn-dark" onclick="setTheme('dark')"  title="Dark"><i class="fa-solid fa-moon"></i></button>
            </div>
            <div class="token-chip"><code>{{ api_token|truncatechars:16 }}…</code></div>
            <div class="status-badge badge-err" id="hdr-status">DISCONNECTED</div>
        </div>
    </header>

    <!-- MAIN -->
    <main>

        <!-- ═══ CONNECTION VIEW ═══ -->
        <section id="view-connection" class="view on">
            <div class="connect-stage">
                <div class="ring-wrap">
                    <div class="ring ring-1" id="ring1"></div>
                    <div class="ring ring-2" id="ring2"></div>
                    <button class="hw-btn hw-unlinked" id="hw-btn" onclick="handleConnect()">
                        <i class="fa-solid fa-wifi" id="hw-ico"></i>
                        <span id="hw-txt">CONNECT</span>
                    </button>
                </div>
                <p class="connect-hint" id="conn-hint">Click to scan for hardware</p>
            </div>
        </section>

        <!-- ═══ MONITORING VIEW ═══ -->
        <section id="view-monitoring" class="view">

            <!-- Process bar -->
            <div class="proc-bar">
                <div class="proc-bar-info">
                    <h3>Treatment Process Control</h3>
                    <p>Toggle real-time wastewater treatment monitoring</p>
                </div>
                <button id="proc-btn" class="proc-btn proc-standby" onclick="toggleProcess()">
                    <i class="fa-solid fa-power-off"></i>
                </button>
            </div>

            <!-- Metrics -->
            <div class="metrics">

                <!-- Temperature -->
                <div class="metric-card mc-temp">
                    <div>
                        <div class="mc-label">Temperature</div>
                        <div class="mc-value" style="color:#fff;"><span id="v-temp">—</span><span class="mc-unit">°C</span></div>
                    </div>
                    <svg class="mc-wave" viewBox="0 0 500 70" preserveAspectRatio="none">
                        <path fill="white" d="M0,35 C100,70 200,0 300,35 C400,70 450,20 500,35 L500,70 L0,70 Z"/>
                    </svg>
                </div>

                <!-- pH -->
                <div class="metric-card mc-ph">
                    <div>
                        <div class="mc-label">pH Level</div>
                        <div class="mc-value" style="color:#fff;"><span id="v-ph">—</span><span class="mc-unit"> pH</span></div>
                    </div>
                    <svg class="mc-wave" viewBox="0 0 500 70" preserveAspectRatio="none">
                        <path fill="white" d="M0,35 C125,70 375,0 500,35 L500,70 L0,70 Z"/>
                    </svg>
                </div>

                <!-- Flow Speed -->
                <div class="metric-card mc-speed">
                    <div>
                        <div class="mc-label">Flow Speed</div>
                        <div class="mc-value" style="color:#fff;"><span id="v-speed">—</span><span class="mc-unit"> L/s</span></div>
                    </div>
                    <svg class="mc-wave" viewBox="0 0 500 70" preserveAspectRatio="none">
                        <path fill="white" d="M0,35 C150,0 350,70 500,35 L500,70 L0,70 Z"/>
                    </svg>
                </div>

                <!-- Color / Quality -->
                <div class="metric-card mc-color" style="display:flex;flex-direction:column;">
                    <div class="mc-label" style="color:var(--tx-2);">Water Quality Sensor</div>
                    <div class="color-name-txt" id="color-name">Detecting…</div>
                    <div class="color-bar" id="color-bar" style="background:rgb(30,64,175);"></div>
                    <div class="rgb-row">
                        <div class="rgb-chip"><span class="rgb-num" id="v-r">30</span><span class="rgb-ch cr">RED</span></div>
                        <div class="rgb-chip"><span class="rgb-num" id="v-g">64</span><span class="rgb-ch cg">GRN</span></div>
                        <div class="rgb-chip"><span class="rgb-num" id="v-b">175</span><span class="rgb-ch cb">BLU</span></div>
                    </div>
                </div>

                <!-- Timer -->
                <div class="metric-card mc-timer">
                    <div>
                        <div class="mc-label">Treatment Duration</div>
                        <div class="timer-big">
                            <span id="t-sec">00</span><span style="opacity:.35;font-size:.55em;">:</span><span id="t-ms" style="font-size:.65em;">00</span>
                        </div>
                        <div class="timer-sub">TOTAL: <span id="t-total">00:00</span></div>
                    </div>
                    <span class="proc-pill" id="proc-pill">STANDBY</span>
                    <svg class="mc-wave" viewBox="0 0 500 70" preserveAspectRatio="none">
                        <path fill="white" d="M0,50 C120,10 380,60 500,30 L500,70 L0,70 Z"/>
                    </svg>
                </div>

            </div><!-- /metrics -->

            <!-- Chart -->
            <div class="chart-card">
                <div class="card-head">
                    <div class="card-title">
                        <i class="fa-solid fa-chart-line"></i>
                        pH & Temperature Trend
                    </div>
                </div>
                <canvas id="phChart"></canvas>
            </div>

            <!-- ══════════════════════════════════════════
                 TREATMENT LOG HISTORY — REAL-TIME
            ══════════════════════════════════════════ -->
            <div class="log-card">
                <div class="log-head">
                    <div class="log-head-left">
                        <div class="card-title">
                            <i class="fa-solid fa-database"></i>
                            Treatment Log History
                        </div>
                        <div class="rt-badge live" id="rt-badge">
                            <div class="rt-dot" id="rt-dot"></div>
                            <span id="rt-lbl">LIVE</span>
                        </div>
                    </div>
                    <div class="log-head-right">
                        <div class="sync-txt" id="sync-info">
                            <i class="fa-solid fa-rotate" style="font-size:9px;"></i>
                            <span id="sync-txt">Syncing…</span>
                        </div>
                        <div class="rpp-sel">
                            <label for="rpp">Rows:</label>
                            <select id="rpp" onchange="pg.setPerPage(+this.value)">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                        <div class="tbl-meta" id="tbl-meta">{{ dataSensor|length }} record{{ dataSensor|length|pluralize }}</div>
                    </div>
                </div>

                <div class="tbl-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>Temp °C</th>
                                <th>pH</th>
                                <th>Red</th>
                                <th>Green</th>
                                <th>Blue</th>
                                <th>Lux</th>
                                <th>Water Quality</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="tbl-body">
                            {% for s in dataSensor %}
                            <tr class="db-row" data-id="{{ s.pk }}" style="display:none;">
                                <td>{{ s.created|date:"Y-m-d H:i:s" }}</td>
                                <td>{% if s.temp %}{{ s.temp|floatformat:2 }}{% else %}<span style="opacity:.3;">—</span>{% endif %}</td>
                                <td class="ph-cell">
                                    {% if s.ph %}
                                        <span class="{% if s.ph < 6 %}ph-acidic{% elif s.ph > 8 %}ph-basic{% else %}ph-neutral{% endif %}">
                                            {{ s.ph|floatformat:2 }}
                                        </span>
                                    {% else %}<span style="opacity:.3;">—</span>{% endif %}
                                </td>
                                <td>{% if s.red %}{{ s.red|floatformat:0 }}{% else %}<span style="opacity:.3;">—</span>{% endif %}</td>
                                <td>{% if s.green %}{{ s.green|floatformat:0 }}{% else %}<span style="opacity:.3;">—</span>{% endif %}</td>
                                <td>{% if s.blue %}{{ s.blue|floatformat:0 }}{% else %}<span style="opacity:.3;">—</span>{% endif %}</td>
                                <td>{% if s.lux %}{{ s.lux|floatformat:1 }}{% else %}<span style="opacity:.3;">—</span>{% endif %}</td>
                                <td style="font-family:var(--font-body);font-size:0.78rem;">
                                    {% if s.red and s.green and s.blue %}
                                    <span style="display:inline-flex;align-items:center;gap:6px;">
                                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:rgb({{ s.red|floatformat:0 }},{{ s.green|floatformat:0 }},{{ s.blue|floatformat:0 }});flex-shrink:0;"></span>
                                        <span class="wq-lbl" data-r="{{ s.red|floatformat:0 }}" data-g="{{ s.green|floatformat:0 }}" data-b="{{ s.blue|floatformat:0 }}"></span>
                                    </span>
                                    {% else %}<span style="opacity:.3;">—</span>{% endif %}
                                </td>
                                <td>
                                    {% if s.red and s.green and s.blue %}
                                    <span class="status-lbl" data-r="{{ s.red|floatformat:0 }}" data-g="{{ s.green|floatformat:0 }}" data-b="{{ s.blue|floatformat:0 }}"></span>
                                    {% else %}<span class="pill pill-bad">No Data</span>{% endif %}
                                </td>
                            </tr>
                            {% empty %}
                            <tr id="empty-row">
                                <td colspan="9">
                                    <div class="empty-state">
                                        <i class="fa-solid fa-wave-square"></i>
                                        <p>No sensor data recorded yet. Waiting for IoT device data…</p>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pg-bar" id="pg-bar">
                    <div class="pg-info" id="pg-info"></div>
                    <div class="pg-btns">
                        <button class="pbt" id="pg-first" onclick="pg.go(1)" title="First"><i class="fa-solid fa-angles-left"></i></button>
                        <button class="pbt" id="pg-prev"  onclick="pg.go(pg.p-1)" title="Prev"><i class="fa-solid fa-angle-left"></i></button>
                        <div id="pg-nums" style="display:flex;gap:3px;"></div>
                        <button class="pbt" id="pg-next"  onclick="pg.go(pg.p+1)" title="Next"><i class="fa-solid fa-angle-right"></i></button>
                        <button class="pbt" id="pg-last"  onclick="pg.go(pg.tot)" title="Last"><i class="fa-solid fa-angles-right"></i></button>
                    </div>
                </div>
            </div><!-- /log-card -->

        </section><!-- /monitoring -->

    </main>
</div><!-- /shell -->

<!-- ═══ OVERLAYS ═══ -->
<div class="modal" id="modal-scan">
    <div class="modal-box">
        <i class="fa-solid fa-satellite-dish fa-spin modal-ico" style="color:var(--cyan);"></i>
        <h3>Establishing Connection…</h3>
        <p>Connecting to Treatment System Controller</p>
    </div>
</div>
<div class="modal" id="modal-done">
    <div class="modal-box">
        <i class="fa-solid fa-circle-check modal-ico" style="color:var(--emerald);"></i>
        <h3>Treatment Completed!</h3>
        <p style="margin-top:6px;">Water purified to transparent state.</p>
        <p style="margin-top:4px;opacity:.6;font-size:.8rem;">Process automatically stopped.</p>
    </div>
</div>

<!-- ═══════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════ -->
<script>
/* ─────────────────────────────────────────────
   DJANGO DATA INJECTION — initial load
───────────────────────────────────────────── */
const DB_DATA = [
    {% for s in dataSensor %}
    {
        id:      {{ s.pk }},
        created: "{{ s.created|date:'Y-m-d H:i:s' }}",
        red:     {{ s.red|default:0 }},
        green:   {{ s.green|default:0 }},
        blue:    {{ s.blue|default:0 }},
        temp:    {{ s.temp|default:0 }},
        lux:     {{ s.lux|default:0 }},
        ph:      {% if s.ph %}{{ s.ph }}{% else %}null{% endif %}
    }{% if not forloop.last %},{% endif %}
    {% endfor %}
];

/* ─────────────────────────────────────────────
   WATER QUALITY HELPERS
───────────────────────────────────────────── */
function isPure(r,g,b){ return r>=200 && g>=200 && b>=200 && (r+g+b)>=630; }

function wqLabel(r,g,b){
    const d = 1 - ((r+g+b)/765);
    if(d>0.7)  return "Highly Polluted Wastewater";
    if(d>0.4)  return "Treatment In Progress";
    if(d>0.15) return "Semi-Purified Water";
    return "Clean Transparent Water";
}

function statusPill(r,g,b){
    return isPure(r,g,b)
        ? '<span class="pill pill-ok">Purified ✓</span>'
        : '<span class="pill pill-proc">On Process</span>';
}

function phClass(ph){
    if(ph < 6)   return 'ph-acidic';
    if(ph > 8)   return 'ph-basic';
    return 'ph-neutral';
}

/* ─────────────────────────────────────────────
   BUILD ROW HTML
───────────────────────────────────────────── */
function buildRow(s){
    const r=parseFloat(s.red||0), g=parseFloat(s.green||0), b=parseFloat(s.blue||0);
    const hasColor = s.red && s.green && s.blue;
    const dash = '<span style="opacity:.3;">—</span>';
    const phVal = s.ph != null ? parseFloat(s.ph) : null;
    const phTd  = phVal != null
        ? `<span class="${phClass(phVal)}">${phVal.toFixed(2)}</span>`
        : dash;
    return `
    <tr class="db-row" data-id="${s.id}">
        <td>${s.created}</td>
        <td>${s.temp!=null?parseFloat(s.temp).toFixed(2):dash}</td>
        <td class="ph-cell">${phTd}</td>
        <td>${s.red!=null?parseFloat(s.red).toFixed(0):dash}</td>
        <td>${s.green!=null?parseFloat(s.green).toFixed(0):dash}</td>
        <td>${s.blue!=null?parseFloat(s.blue).toFixed(0):dash}</td>
        <td>${s.lux!=null?parseFloat(s.lux).toFixed(1):dash}</td>
        <td style="font-family:var(--font-body);font-size:0.78rem;">
            ${hasColor?`<span style="display:inline-flex;align-items:center;gap:6px;">
                <span style="width:8px;height:8px;border-radius:50%;background:rgb(${r},${g},${b});flex-shrink:0;display:inline-block;"></span>
                ${wqLabel(r,g,b)}</span>`:dash}
        </td>
        <td>${hasColor?statusPill(r,g,b):'<span class="pill pill-bad">No Data</span>'}</td>
    </tr>`;
}

