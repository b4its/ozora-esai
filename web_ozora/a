/* ─────────────────────────────────────────────
   HARDWARE / PROCESS SIMULATION
───────────────────────────────────────────── */
let linked=false, procOn=false, procDone=false;
let timerInt, sensorInt, logInt;
let t0=0, elapsed=0, simLog=[];
const sim={
    iPH:11.5, tPH:7.0,
    iTemp:35, tTemp:28,
    duration:5000, intensity:1.0
};

const U={
    vTemp:  ()=>document.getElementById('v-temp'),
    vPH:    ()=>document.getElementById('v-ph'),
    vSpeed: ()=>document.getElementById('v-speed'),
    vR:     ()=>document.getElementById('v-r'),
    vG:     ()=>document.getElementById('v-g'),
    vB:     ()=>document.getElementById('v-b'),
    colorBar: ()=>document.getElementById('color-bar'),
    colorName:()=>document.getElementById('color-name'),
    tSec:   ()=>document.getElementById('t-sec'),
    tMs:    ()=>document.getElementById('t-ms'),
    tTotal: ()=>document.getElementById('t-total'),
    pill:   ()=>document.getElementById('proc-pill'),
    procBtn:()=>document.getElementById('proc-btn'),
    hdrSt:  ()=>document.getElementById('hdr-status'),
};

function handleConnect(){
    if(!linked){
        document.getElementById('modal-scan').classList.add('on');
        setTimeout(()=>{
            document.getElementById('modal-scan').classList.remove('on');
            setLinked(true);
        },1300);
    } else {
        if(procOn) stopProcess();
        setLinked(false);
    }
}

function setLinked(v){
    linked=v;
    const btn=document.getElementById('hw-btn');
    const ico=document.getElementById('hw-ico');
    const txt=document.getElementById('hw-txt');
    const hint=document.getElementById('conn-hint');
    const r1=document.getElementById('ring1'), r2=document.getElementById('ring2');
    if(v){
        btn.className='hw-btn hw-linked';
        ico.className='fa-solid fa-link';
        txt.textContent='LINKED';
        hint.textContent='Connected to Treatment System Controller';
        r1.classList.add('pulse'); r2.classList.add('pulse');
        U.hdrSt().className='status-badge badge-ok';
        U.hdrSt().textContent='CONNECTED';
        document.getElementById('nl-mon').classList.remove('disabled');
        setTimeout(()=>{ switchView('monitoring'); initChart(); },600);
    } else {
        btn.className='hw-btn hw-unlinked';
        ico.className='fa-solid fa-wifi';
        txt.textContent='CONNECT';
        hint.textContent='Click to scan for hardware';
        r1.classList.remove('pulse'); r2.classList.remove('pulse');
        U.hdrSt().className='status-badge badge-err';
        U.hdrSt().textContent='DISCONNECTED';
        document.getElementById('nl-mon').classList.add('disabled');
    }
}

function toggleProcess(){
    if(procDone){
        procDone=false; elapsed=0; sim.intensity=1.0;
        U.procBtn().className='proc-btn proc-standby';
        U.procBtn().innerHTML='<i class="fa-solid fa-power-off"></i>';
        U.pill().textContent='STANDBY';
        return;
    }
    procOn=!procOn;
    if(procOn){
        U.procBtn().className='proc-btn proc-active';
        U.procBtn().innerHTML='<i class="fa-solid fa-pause"></i>';
        U.pill().textContent='TREATING';
        t0=Date.now()-elapsed;
        timerInt  = setInterval(tick,   50);
        sensorInt = setInterval(sense, 120);
        logInt    = setInterval(logRow,600);
        sense(); logRow();
    } else {
        stopProcess();
        U.pill().textContent='PAUSED';
    }
}

function stopProcess(){
    procOn=false;
    clearInterval(timerInt); clearInterval(sensorInt); clearInterval(logInt);
    U.procBtn().className='proc-btn proc-standby';
    U.procBtn().innerHTML='<i class="fa-solid fa-power-off"></i>';
}

function finish(){
    procOn=false; procDone=true;
    clearInterval(timerInt); clearInterval(sensorInt); clearInterval(logInt);
    U.procBtn().className='proc-btn proc-done';
    U.procBtn().innerHTML='<i class="fa-solid fa-check"></i>';
    U.pill().textContent='COMPLETED';
    const m=document.getElementById('modal-done');
    m.classList.add('on');
    setTimeout(()=>m.classList.remove('on'),3500);
    logRow();
}

function tick(){
    elapsed=Date.now()-t0;
    const s=Math.floor(elapsed/1000);
    const ms=Math.floor((elapsed%1000)/10);
    const mn=Math.floor(s/60);
    U.tSec().textContent=((s%60)).toString().padStart(2,'0');
    U.tMs().textContent=ms.toString().padStart(2,'0');
    U.tTotal().textContent=`${mn.toString().padStart(2,'0')}:${(s%60).toString().padStart(2,'0')}`;
}

function sense(){
    const p=Math.min(elapsed/sim.duration,1);
    let temp=sim.iTemp-(sim.iTemp-sim.tTemp)*p+(Math.random()*1.5-.75);
    temp=Math.max(sim.tTemp,Math.min(sim.iTemp,temp));
    U.vTemp().textContent=temp.toFixed(1);

    let ph=sim.iPH-(sim.iPH-sim.tPH)*p+(Math.random()*.3-.15);
    ph=Math.max(sim.tPH,Math.min(sim.iPH,ph));
    U.vPH().textContent=ph.toFixed(1);

    const spd=2.5+Math.sin(p*Math.PI*2)*.8+(Math.random()*.4-.2);
    U.vSpeed().textContent=Math.max(1,spd).toFixed(1);

    sim.intensity=Math.max(0,1-p);
    let r=Math.floor(30+170*(1-sim.intensity)+(Math.random()*20-10));
    let g=Math.floor(64+156*(1-sim.intensity)+(Math.random()*20-10));
    let b=Math.floor(175+65*(1-sim.intensity)+(Math.random()*20-10));
    r=Math.max(0,Math.min(255,r));
    g=Math.max(0,Math.min(255,g));
    b=Math.max(0,Math.min(255,b));
    U.vR().textContent=r; U.vG().textContent=g; U.vB().textContent=b;
    U.colorBar().style.backgroundColor=`rgb(${r},${g},${b})`;
    U.colorName().textContent=wqLabel(r,g,b);
    if(procOn && isPure(r,g,b)) finish();
}

function logRow(){
    const now=new Date();
    const time=`${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}:${now.getSeconds().toString().padStart(2,'0')}`;
    const temp=parseFloat(U.vTemp().textContent)||0;
    const ph  =parseFloat(U.vPH().textContent)||0;
    const r=parseInt(U.vR().textContent)||0;
    const gv=parseInt(U.vG().textContent)||0;
    const bv=parseInt(U.vB().textContent)||0;
    const wq=U.colorName().textContent;
    const pure=isPure(r,gv,bv);
    const statusHtml = procDone
        ? '<span class="pill pill-ok">Completed ✓</span>'
        : (pure ? '<span class="pill pill-ok">Purified ✓</span>' : '<span class="pill pill-proc">On Process</span>');
    const dash='<span style="opacity:.3;">—</span>';
    const phCl=phClass(ph);
    const row=document.createElement('tr');
    row.className='rt-row';
    row.innerHTML=`
        <td>${time}</td>
        <td>${temp.toFixed(1)}</td>
        <td class="ph-cell"><span class="${phCl}">${ph.toFixed(1)}</span></td>
        <td>${r}</td><td>${gv}</td><td>${bv}</td>
        <td>${dash}</td>
        <td style="font-family:var(--font-body);font-size:0.78rem;">
            <span style="display:inline-flex;align-items:center;gap:6px;">
            <span style="width:8px;height:8px;border-radius:50%;background:rgb(${r},${gv},${bv});display:inline-block;flex-shrink:0;"></span>
            ${wq}</span>
        </td>
        <td>${statusHtml}</td>`;
    const tbody=document.getElementById('tbl-body');
    const first=tbody.querySelector('.db-row');
    const empty=document.getElementById('empty-row');
    if(first) tbody.insertBefore(row,first);
    else if(empty) tbody.insertBefore(row,empty);
    else tbody.insertBefore(row,tbody.firstChild);
    const rt=[...tbody.querySelectorAll('.rt-row')];
    if(rt.length>100) rt[rt.length-1].remove();
    pg.p=1; pg.render();

    // Feed chart
    simLog.push({time,ph,temp,r,g:gv,b:bv});
    if(simLog.length>30) simLog.shift();
    chartData=[...chartData.slice(-10), ...simLog].slice(-30).map(d=>d);
    // Merge
    const merged = [...(chartData.length?[]:DB_DATA.slice(-10).map(d=>({time:d.created.substr(11,8),ph:d.ph!=null?parseFloat(d.ph):null,temp:parseFloat(d.temp)}))), ...simLog].slice(-30);
    chart && (chart.data.labels=merged.map(d=>d.time),
               chart.data.datasets[0].data=merged.map(d=>d.ph),
               chart.data.datasets[1].data=merged.map(d=>d.temp),
               chart.update('none'));
}

