let chart=null, chartData=[];

function seedChart(){
    chartData = DB_DATA.slice(-30).map(d=>({
        time:  d.created.substr(11,8),
        ph:    d.ph!=null ? parseFloat(d.ph) : null,
        temp:  parseFloat(d.temp)
    }));
}

function initChart(){
    if(chart){ chart.destroy(); chart=null; }
    const ctx=document.getElementById('phChart').getContext('2d');
    const cs=getComputedStyle(document.documentElement);
    const tc=cs.getPropertyValue('--tx').trim();
    const bc=cs.getPropertyValue('--border').trim();
    const bc2=cs.getPropertyValue('--border-2').trim();

    chart = new Chart(ctx,{
        type:'line',
        data:{
            labels: chartData.map(d=>d.time),
            datasets:[
                {
                    label:'pH Level',
                    data: chartData.map(d=>d.ph),
                    borderColor:'#EC4899', backgroundColor:'rgba(236,72,153,0.08)',
                    borderWidth:2.5, tension:0.4, fill:true,
                    pointRadius:3, pointBackgroundColor:'#EC4899',
                    pointBorderColor:'#fff', pointBorderWidth:2,
                    spanGaps:true
                },
                {
                    label:'Temperature °C',
                    data: chartData.map(d=>d.temp),
                    borderColor:'#F59E0B', backgroundColor:'rgba(245,158,11,0.05)',
                    borderWidth:2, tension:0.4, fill:false,
                    pointRadius:2, pointBackgroundColor:'#F59E0B',
                    pointBorderColor:'#fff', pointBorderWidth:1.5,
                    yAxisID:'y2', spanGaps:true
                }
            ]
        },
        options:{
            responsive:true, maintainAspectRatio:true, aspectRatio:3,
            plugins:{
                legend:{ display:true, position:'top', labels:{ color:tc, font:{family:"'Space Grotesk',sans-serif",size:12,weight:'600'}, usePointStyle:true, pointStyleWidth:8 } },
                tooltip:{ backgroundColor:'rgba(13,17,23,0.95)', titleColor:'#fff', bodyColor:'rgba(255,255,255,0.7)', borderColor:bc2, borderWidth:1, padding:12, cornerRadius:10 }
            },
            scales:{
                y:  { beginAtZero:false, min:5, max:13, grid:{color:bc}, ticks:{color:tc,font:{family:"'JetBrains Mono',monospace",size:11},callback:v=>v.toFixed(1)+'pH'}, title:{display:true,text:'pH Level',color:tc,font:{family:"'Space Grotesk'",size:12,weight:'600'}} },
                y2: { position:'right', beginAtZero:false, min:18, max:42, grid:{drawOnChartArea:false}, ticks:{color:'#F59E0B',font:{family:"'JetBrains Mono',monospace",size:11},callback:v=>v+'°C'}, title:{display:true,text:'Temp °C',color:'#F59E0B',font:{family:"'Space Grotesk'",size:12,weight:'600'}} },
                x:  { grid:{color:bc}, ticks:{color:tc,font:{family:"'JetBrains Mono',monospace",size:10},maxRotation:45}, title:{display:true,text:'Time',color:tc,font:{family:"'Space Grotesk'",size:12,weight:'600'}} }
            },
            interaction:{ intersect:false, mode:'index' }
        }
    });
}

function refreshChart(){
    if(!chart) return;
    chart.data.labels           = chartData.map(d=>d.time);
    chart.data.datasets[0].data = chartData.map(d=>d.ph);
    chart.data.datasets[1].data = chartData.map(d=>d.temp);
    chart.update('none');
}

function updateChartTheme(){
    if(!chart) return;
    const cs=getComputedStyle(document.documentElement);
    const tc=cs.getPropertyValue('--tx').trim();
    const bc=cs.getPropertyValue('--border').trim();
    chart.options.plugins.legend.labels.color=tc;
    ['x','y'].forEach(a=>{
        chart.options.scales[a].grid.color=bc;
        chart.options.scales[a].ticks.color=tc;
        chart.options.scales[a].title.color=tc;
    });
    chart.update('none');
}

